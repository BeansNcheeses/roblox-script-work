SliderBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)

SliderBtn.MouseButton1Down:Connect(function()
    local move = game:GetService("UserInputService").InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            local relativeX = input.Position.X - SliderBack.AbsolutePosition.X
            local percent = math.clamp(relativeX / SliderBack.AbsoluteSize.X, 0, 1)
            SliderBtn.Position = UDim2.new(percent, -10, 0, -5)
            Settings.FOV = math.floor(percent * 800)
            SliderLabel.Text = "FOV SIZE: " .. Settings.FOV
        end
    end)
    game:GetService("UserInputService").InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            move:Disconnect()
        end
    end)
end)

