local DrRayLibrary = loadstring(game:HttpGet("https://raw.githubusercontent.com/AZYsGithub/DrRay-UI-Library/main/DrRay.lua"))()

local window = DrRayLibrary:Load("Arsenal Chaos", "Default")

-- Settings Variable
getgenv().Settings = {
    Aimbot = false,
    TeamCheck = true,
    ESP = false,
    Speed = 16
}

-- 1. COMBAT TAB
local combatTab = DrRayLibrary.newTab("Combat", "rbxassetid://4483362458")

combatTab.newToggle("Enable Aimbot", "Locks onto players", false, function(state)
    getgenv().Settings.Aimbot = state
end)

combatTab.newButton("Infinite Ammo & No Recoil", "Click once per life", function()
    for _, v in pairs(getgc(true)) do
        if type(v) == "table" and (rawget(v, "Ammo") or rawget(v, "Clip")) then
            v.Ammo = 999
            v.Clip = 999
            v.MaxAmmo = 999
            v.Recoil = 0
            v.Spread = 0
        end
    end
end)

-- 2. VISUALS TAB
local visualsTab = DrRayLibrary.newTab("Visuals", "rbxassetid://4483362458")

visualsTab.newToggle("Box ESP", "See through walls", false, function(state)
    getgenv().Settings.ESP = state
end)

-- 3. MOVEMENT TAB
local moveTab = DrRayLibrary.newTab("Movement", "rbxassetid://4483362458")

moveTab.newSlider("WalkSpeed", "Default is 16", 100, false, function(val)
    if game.Players.LocalPlayer.Character then
        game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = val
    end
end)

-- LOGIC ENGINE
game:GetService("RunService").RenderStepped:Connect(function()
    local lp = game.Players.LocalPlayer
    local cam = workspace.CurrentCamera

    -- Aimbot (Simplified for mobile stability)
    if getgenv().Settings.Aimbot then
        local nearest = nil
        local lastDist = 200 -- Fixed FOV for stability
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= lp and v.Character and v.Character:FindFirstChild("Head") and v.Character.Humanoid.Health > 0 then
                if v.Team ~= lp.Team then
                    local pos, onScreen = cam:WorldToScreenPoint(v.Character.Head.Position)
                    if onScreen then
                        local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)).Magnitude
                        if dist < lastDist then
                            lastDist = dist
                            nearest = v
                        end
                    end
                end
            end
        end
        if nearest then
            cam.CFrame = CFrame.new(cam.CFrame.Position, nearest.Character.Head.Position)
        end
    end

    -- ESP (Using Highlights - the most stable visual)
    if getgenv().Settings.ESP then
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= lp and v.Character and v.Character.Humanoid.Health > 0 then
                if not v.Character:FindFirstChild("Highlight") then
                    local h = Instance.new("Highlight", v.Character)
                    h.FillColor = (v.Team == lp.Team) and Color3.new(0,1,0) or Color3.new(1,0,0)
                    h.OutlineColor = Color3.new(1,1,1)
                end
            end
        end
    end
end)
