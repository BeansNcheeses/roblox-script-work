-- 5. LOGIC ENGINE
local function IsVisible(part)
    local cam = workspace.CurrentCamera
    local ray = RaycastParams.new()
    ray.FilterDescendantsInstances = {game.Players.LocalPlayer.Character, part.Parent}
    ray.FilterType = Enum.RaycastFilterType.Exclude
    local result = workspace:Raycast(cam.CFrame.Position, part.Position - cam.CFrame.Position, ray)
    return result == nil
end

game:GetService("RunService").RenderStepped:Connect(function()
    local cam = workspace.CurrentCamera
    local lp = game.Players.LocalPlayer
    
    FOVFrame.Size = UDim2.new(0, Settings.FOV * 2, 0, Settings.FOV * 2)
    
    if Settings.Aimbot then
        local nearest = nil
        local lastDist = Settings.FOV
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= lp and v.Character and v.Character:FindFirstChild("Head") and v.Character.Humanoid.Health > 0 then
                if Settings.TeamCheck and v.Team == lp.Team then continue end
                
                local pos, onScreen = cam:WorldToScreenPoint(v.Character.Head.Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)).Magnitude
                    if dist < lastDist then
                        if not Settings.VisibleOnly or IsVisible(v.Character.Head) then
                            lastDist = dist
                            nearest = v
                        end
                    end
                end
            end
        end
        if nearest then
            cam.CFrame = CFrame.new(cam.CFrame.Position, nearest.Character.Head.Position)
        end
    end

    if Settings.ESP then
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= lp and v.Character and v.Character.Humanoid.Health > 0 then
                if not v.Character:FindFirstChild("Highlight") then
                    local h = Instance.new("Highlight", v.Character)
                    h.FillColor = (v.Team == lp.Team) and Color3.new(0,1,0) or Color3.new(1,0,0)
                end
            end
        end
    end
end)
