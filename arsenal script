local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Arsenal Chaos Hub",
   LoadingTitle = "Final Stability Patch",
   LoadingSubtitle = "by Gemini",
   ConfigurationSaving = {Enabled = false},
   KeySystem = false
})

local Settings = {
    Aimbot = false,
    TeamCheck = true,
    FOV = 100,
    ShowFOV = true,
    ESP = false
}

-- COMBAT TAB
local Combat = Window:CreateTab("Combat", 4483362458)

Combat:CreateToggle({
   Name = "Enable Aimbot",
   CurrentValue = false,
   Flag = "AimToggle",
   Callback = function(Value) Settings.Aimbot = Value end,
})

Combat:CreateSlider({
   Name = "Aimbot FOV",
   Range = {30, 500},
   Increment = 5,
   CurrentValue = 100,
   Flag = "FOVSlider",
   Callback = function(Value) Settings.FOV = Value end,
})

-- FIXED AMMO SECTION
Combat:CreateSection("Weapon Mods")

Combat:CreateButton({
   Name = "Infinite Ammo & No Recoil",
   Callback = function()
       local count = 0
       for _, v in pairs(getgc(true)) do
           if type(v) == "table" and rawget(v, "Ammo") then
               v.Ammo = 999
               v.MaxAmmo = 999
               v.Recoil = 0
               v.Spread = 0
               count = count + 1
           end
       end
       Rayfield:Notify({Title = "Applied", Content = "Found " .. count .. " gun tables.", Duration = 3})
   end,
})

-- VISUALS TAB
local Visuals = Window:NewTab("Visuals", 4483362458)

Visuals:CreateToggle({
   Name = "Box ESP",
   CurrentValue = false,
   Flag = "ESPToggle",
   Callback = function(Value) 
       Settings.ESP = Value 
   end,
})

Visuals:CreateToggle({
   Name = "Show FOV Circle",
   CurrentValue = true,
   Flag = "ShowFOV",
   Callback = function(Value) Settings.ShowFOV = Value end,
})

-- MOVEMENT TAB
local Movement = Window:CreateTab("Movement", 4483362458)
Movement:CreateSlider({
   Name = "WalkSpeed",
   Range = {16, 100},
   Increment = 1,
   CurrentValue = 16,
   Callback = function(v) if game.Players.LocalPlayer.Character then game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = v end end,
})

-- FOV DRAWING
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 1
FOVCircle.Color = Color3.fromRGB(255, 255, 255)
FOVCircle.Filled = false

-- CORE LOOP
game:GetService("RunService").RenderStepped:Connect(function()
    local cam = workspace.CurrentCamera
    local lp = game.Players.LocalPlayer
    
    FOVCircle.Visible = Settings.ShowFOV
    FOVCircle.Radius = Settings.FOV
    FOVCircle.Position = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)

    -- Aimbot Logic
    if Settings.Aimbot and lp.Character then
        local nearest = nil
        local dist = math.huge
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= lp and v.Character and v.Character:FindFirstChild("Head") then
                if Settings.TeamCheck and v.Team == lp.Team then continue end
                local pos, onScreen = cam:WorldToScreenPoint(v.Character.Head.Position)
                if onScreen then
                    local mag = (Vector2.new(pos.X, pos.Y) - FOVCircle.Position).Magnitude
                    if mag < Settings.FOV and mag < dist then
                        dist = mag
                        nearest = v
                    end
                end
            end
        end
        if nearest then
            cam.CFrame = CFrame.new(cam.CFrame.Position, nearest.Character.Head.Position)
        end
    end

    -- Box ESP Logic (Using BillboardGui for Mobile Stability)
    if Settings.ESP then
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= lp and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                local hrp = v.Character.HumanoidRootPart
                if not hrp:FindFirstChild("BoxESP") then
                    local b = Instance.new("BillboardGui", hrp)
                    b.Name = "BoxESP"
                    b.AlwaysOnTop = true
                    b.Size = UDim2.new(4, 0, 5, 0)
                    local f = Instance.new("Frame", b)
                    f.Size = UDim2.new(1, 0, 1, 0)
                    f.BackgroundTransparency = 1
                    local s = Instance.new("UIStroke", f)
                    s.Thickness = 2
                    s.Color = (v.Team == lp.Team) and Color3.new(0,1,0) or Color3.new(1,0,0)
                end
            end
        end
    else
        for _, v in pairs(game.Players:GetPlayers()) do
            if v.Character and v.Character:FindFirstChild("HumanoidRootPart") and v.Character.HumanoidRootPart:FindFirstChild("BoxESP") then
                v.Character.HumanoidRootPart.BoxESP:Destroy()
            end
        end
    end
end)
