-- FOV CIRCLE DRAWING
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 2
FOVCircle.Color = Color3.new(1, 1, 1)
FOVCircle.Filled = false
FOVCircle.Visible = true

-- WALL CHECK FUNCTION
local function IsPlayerVisible(target)
    local char = game.Players.LocalPlayer.Character
    local cam = workspace.CurrentCamera
    local castPoints = {target.Position}
    local ignoreList = {char, target.Parent}
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = ignoreList
    params.FilterType = Enum.RaycastFilterType.Exclude
    
    local result = workspace:Raycast(cam.CFrame.Position, target.Position - cam.CFrame.Position, params)
    return result == nil
end

-- MAIN ENGINE
game:GetService("RunService").RenderStepped:Connect(function()
    local lp = game.Players.LocalPlayer
    local cam = workspace.CurrentCamera
    local center = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)

    -- Update FOV Circle
    FOVCircle.Radius = getgenv().Settings.FOV
    FOVCircle.Position = center
    FOVCircle.Visible = true

    -- Aimbot Logic
    if getgenv().Settings.Aimbot then
        local nearest = nil
        local shortestDist = getgenv().Settings.FOV

        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= lp and v.Character and v.Character:FindFirstChild("Head") and v.Character.Humanoid.Health > 0 then
                if getgenv().Settings.TeamCheck and v.Team == lp.Team then continue end
                
                local pos, onScreen = cam:WorldToScreenPoint(v.Character.Head.Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                    if dist < shortestDist then
                        if getgenv().Settings.VisibleOnly then
                            if IsPlayerVisible(v.Character.Head) then
                                shortestDist = dist
                                nearest = v
                            end
                        else
                            shortestDist = dist
                            nearest = v
                        end
                    end
                end
            end
        end
        if nearest then
            cam.CFrame = CFrame.new(cam.CFrame.Position, nearest.Character.Head.Position)
        end
    end

    -- ESP Logic
    if getgenv().Settings.ESP then
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= lp and v.Character and v.Character.Humanoid.Health > 0 then
                if not v.Character:FindFirstChild("Highlight") then
                    local h = Instance.new("Highlight", v.Character)
                    h.FillColor = (v.Team == lp.Team) and Color3.new(0,1,0) or Color3.new(1,0,0)
                end
            end
        end
    end
end)
