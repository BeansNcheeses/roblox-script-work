-- Main Loop
RunService.RenderStepped:Connect(function()
    -- Update ESP
    if Config.ESP.Enabled then
        UpdateESP()
    end
    
    -- Update FOV Circle
    if FOV_Circle then
        FOV_Circle.Position = Vector2.new(Mouse.X, Mouse.Y + 36)
        FOV_Circle.Visible = Config.Aimbot.Enabled and Config.Aimbot.ShowFOV
    end
    
    -- Update Crosshair
    if Config.Visual.CustomCrosshair then
        local centerX = Camera.ViewportSize.X / 2
        local centerY = Camera.ViewportSize.Y / 2
        local size = Config.Visual.CrosshairSize
        
        if CrosshairLines[1] then
            CrosshairLines[1].From = Vector2.new(centerX, centerY - size - 2)
            CrosshairLines[1].To = Vector2.new(centerX, centerY - 2)
        end
        if CrosshairLines[2] then
            CrosshairLines[2].From = Vector2.new(centerX, centerY + 2)
            CrosshairLines[2].To = Vector2.new(centerX, centerY + size + 2)
        end
        if CrosshairLines[3] then
            CrosshairLines[3].From = Vector2.new(centerX - size - 2, centerY)
            CrosshairLines[3].To = Vector2.new(centerX - 2, centerY)
        end
        if CrosshairLines[4] then
            CrosshairLines[4].From = Vector2.new(centerX + 2, centerY)
            CrosshairLines[4].To = Vector2.new(centerX + size + 2, centerY)
        end
        if CrosshairLines[5] then
            CrosshairLines[5].Position = Vector2.new(centerX, centerY)
        end
        
        -- Rainbow mode
        if Config.Visual.RainbowMode then
            local hue = tick() % 5 / 5
            local color = Color3.fromHSV(hue, 1, 1)
            for _, line in pairs(CrosshairLines) do
                line.Color = color
            end
        end
    end
    
    -- Aimbot
    if Config.Aimbot.Enabled and UserInputService:IsMouseButtonPressed(Enum.UserInputType[Config.Aimbot.Key]) then
        local target = GetClosestPlayer()
        if target then
            AimAt(target)
        end
    end
    
    -- Speed Hack
    if Config.Player.SpeedHack and LocalPlayer.Character then
        local humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid.WalkSpeed = Config.Player.SpeedValue
        end
    end
    
    -- Jump Power
    if Config.Player.JumpPower and LocalPlayer.Character then
        local humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid.JumpPower = Config.Player.JumpValue
        end
    end
    
    -- Spin Bot
    if Config.Player.SpinBot and LocalPlayer.Character then
        local rootPart = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if rootPart then
            rootPart.CFrame = rootPart.CFrame * CFrame.Angles(0, math.rad(Config.Player.SpinSpeed), 0)
        end
    end
    
    -- Anti Aim (simplified)
    if Config.Player.AntiAim and LocalPlayer.Character then
        local rootPart = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if rootPart then
            rootPart.CFrame = CFrame.new(rootPart.Position) * CFrame.Angles(0, math.random(0, 360), 0)
        end
    end
    
    -- No Clip
    if Config.Player.NoClip and LocalPlayer.Character then
        for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end
    
    -- Third Person
    if Config.Player.ThirdPerson then
        Camera.CameraType = Enum.CameraType.Custom
        Camera.FieldOfView = 70
        -- Would need additional setup for proper third person
    end
    
    -- Rainbow FOV
    if Config.Aimbot.Enabled and Config.Visual.RainbowMode and FOV_Circle then
        local hue = tick() % 5 / 5
        FOV_Circle.Color = Color3.fromHSV(hue, 1, 1)
    end
end)

-- Input Handling
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    -- Infinite Jump
    if Config.Player.InfiniteJump and input.KeyCode == Enum.KeyCode.Space then
        if LocalPlayer.Character then
            local humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            if humanoid then
                humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end
    end
    
    -- Bunny Hop
    if Config.Player.BHop and input.KeyCode == Enum.KeyCode.Space then
        while UserInputService:IsKeyDown(Enum.KeyCode.Space) do
            if LocalPlayer.Character then
                local humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                if humanoid and humanoid.FloorMaterial ~= Enum.Material.Air then
                    humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                end
            end
            RunService.RenderStepped:Wait()
        end
    end
end)

-- Fly Logic
local flyConnection
local flyVelocity = Vector3.new(0, 0, 0)

local function StartFly()
    if flyConnection then flyConnection:Disconnect() end
    
    local bodyGyro = Instance.new("BodyGyro")
    local bodyVelocity = Instance.new("BodyVelocity")
    
    bodyGyro.P = 9e4
    bodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    bodyGyro.CFrame = LocalPlayer.Character.HumanoidRootPart.CFrame
    
    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    bodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    
    bodyGyro.Parent = LocalPlayer.Character.HumanoidRootPart
    bodyVelocity.Parent = LocalPlayer.Character.HumanoidRootPart
    
    flyConnection = RunService.RenderStepped:Connect(function()
        if not Config.Player.Fly then
            bodyGyro:Destroy()
            bodyVelocity:Destroy()
            flyConnection:Disconnect()
            return
        end
        
        local moveDirection = Vector3.new(0, 0, 0)
        
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then
            moveDirection = moveDirection + Camera.CFrame.LookVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then
            moveDirection = moveDirection - Camera.CFrame.LookVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then
            moveDirection = moveDirection - Camera.CFrame.RightVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then
            moveDirection = moveDirection + Camera.CFrame.RightVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
            moveDirection = moveDirection + Vector3.new(0, 1, 0)
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
            moveDirection = moveDirection - Vector3.new(0, 1, 0)
        end
        
        bodyVelocity.Velocity = moveDirection.Unit * Config.Player.FlySpeed
        bodyGyro.CFrame = Camera.CFrame
    end)
end

