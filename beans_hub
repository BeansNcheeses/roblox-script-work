-- MAIN LOOP
print("Starting main loop...")

RunService.RenderStepped:Connect(function()
    -- Update ESP
    UpdateESP()
    
    -- Update FOV Circle
    FOV_Circle.Position = Vector2.new(Mouse.X, Mouse.Y + 36)
    FOV_Circle.Visible = Aimbot.Enabled and Aimbot.ShowFOV
    
    -- Aimbot
    if Aimbot.Enabled then
        if UserInputService:IsMouseButtonPressed(Aimbot.Key) then
            local target = GetClosestPlayer()
            if target and target.Character and target.Character:FindFirstChild("Head") then
                local targetPos = target.Character.Head.Position
                local cameraCF = CFrame.new(Camera.CFrame.Position, targetPos)
                Camera.CFrame = Camera.CFrame:Lerp(cameraCF, Aimbot.Smoothness)
            end
        end
    end
end)

