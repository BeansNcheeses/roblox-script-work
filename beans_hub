-- Crosshair
local function CreateCrosshair()
    for _, line in pairs(CrosshairLines) do
        line:Remove()
    end
    CrosshairLines = {}
    
    if Config.Visual.CustomCrosshair then
        local centerX = Camera.ViewportSize.X / 2
        local centerY = Camera.ViewportSize.Y / 2
        local size = Config.Visual.CrosshairSize
        local thickness = Config.Visual.CrosshairThickness
        
        -- Top
        local top = Drawing.new("Line")
        top.Thickness = thickness
        top.Color = Config.Visual.CrosshairColor
        top.From = Vector2.new(centerX, centerY - size - 2)
        top.To = Vector2.new(centerX, centerY - 2)
        top.Visible = true
        table.insert(CrosshairLines, top)
        
        -- Bottom
        local bottom = Drawing.new("Line")
        bottom.Thickness = thickness
        bottom.Color = Config.Visual.CrosshairColor
        bottom.From = Vector2.new(centerX, centerY + 2)
        bottom.To = Vector2.new(centerX, centerY + size + 2)
        bottom.Visible = true
        table.insert(CrosshairLines, bottom)
        
        -- Left
        local left = Drawing.new("Line")
        left.Thickness = thickness
        left.Color = Config.Visual.CrosshairColor
        left.From = Vector2.new(centerX - size - 2, centerY)
        left.To = Vector2.new(centerX - 2, centerY)
        left.Visible = true
        table.insert(CrosshairLines, left)
        
        -- Right
        local right = Drawing.new("Line")
        right.Thickness = thickness
        right.Color = Config.Visual.CrosshairColor
        right.From = Vector2.new(centerX + 2, centerY)
        right.To = Vector2.new(centerX + size + 2, centerY)
        right.Visible = true
        table.insert(CrosshairLines, right)
        
        -- Center dot
        local dot = Drawing.new("Circle")
        dot.Radius = thickness
        dot.Filled = true
