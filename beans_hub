-- ESP CREATION FUNCTION
function CreateESP(player)
    if player == LocalPlayer then return end
    if ESPObjects[player] then return end
    
    print("Creating ESP for:", player.Name)
    
    ESPObjects[player] = {
        Box = Drawing.new("Quad"),
        Tracer = Drawing.new("Line"),
        Name = Drawing.new("Text")
    }
    
    -- Setup Box
    ESPObjects[player].Box.Thickness = 1
    ESPObjects[player].Box.Color = Color3.fromRGB(255, 0, 0)
    ESPObjects[player].Box.Filled = false
    ESPObjects[player].Box.Visible = false
    
    -- Setup Tracer
    ESPObjects[player].Tracer.Thickness = 1
    ESPObjects[player].Tracer.Color = Color3.fromRGB(255, 0, 0)
    ESPObjects[player].Tracer.Visible = false
    
    -- Setup Name
    ESPObjects[player].Name.Size = 14
    ESPObjects[player].Name.Center = true
    ESPObjects[player].Name.Outline = true
    ESPObjects[player].Name.Color = Color3.fromRGB(255, 255, 255)
    ESPObjects[player].Name.Visible = false
end

-- ESP REMOVAL FUNCTION
function RemoveESP(player)
    if not ESPObjects[player] then return end
    
    if ESPObjects[player].Box then ESPObjects[player].Box:Remove() end
    if ESPObjects[player].Tracer then ESPObjects[player].Tracer:Remove() end
    if ESPObjects[player].Name then ESPObjects[player].Name:Remove() end
    
    ESPObjects[player] = nil
    print("Removed ESP for:", player.Name)
end

-- ESP UPDATE FUNCTION
function UpdateESP()
    if not ESP.Enabled then
        -- Hide all ESP
        for player, objects in pairs(ESPObjects) do
            if objects.Box then objects.Box.Visible = false end
            if objects.Tracer then objects.Tracer.Visible = false end
            if objects.Name then objects.Name.Visible = false end
        end
        return
    end
    
    for player, objects in pairs(ESPObjects) do
        -- Check if player is valid
        if not player or not player.Parent then
            RemoveESP(player)
            continue
        end
        
        local character = player.Character
        if not character then
            objects.Box.Visible = false
            objects.Tracer.Visible = false
            objects.Name.Visible = false
            continue
        end
        
        local head = character:FindFirstChild("Head")
        local root = character:FindFirstChild("HumanoidRootPart")
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        
        if not head or not root or not humanoid then
            objects.Box.Visible = false
            objects.Tracer.Visible = false
            objects.Name.Visible = false
            continue
        end
        
        -- Team Check
        if ESP.TeamCheck and player.Team == LocalPlayer.Team then
            objects.Box.Visible = false
            objects.Tracer.Visible = false
            objects.Name.Visible = false
            continue
        end
        
        -- Distance Check
        local distance = (root.Position - Camera.CFrame.Position).Magnitude
        if distance > ESP.MaxDistance then
            objects.Box.Visible = false
            objects.Tracer.Visible = false
            objects.Name.Visible = false
            continue
        end
        
        -- Get Screen Positions
        local headPos, headVisible = Camera:WorldToViewportPoint(head.Position)
        local rootPos = Camera:WorldToViewportPoint(root.Position)
        local legPos = Camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3, 0))
        
        if not headVisible then
            objects.Box.Visible = false
            objects.Tracer.Visible = false
            objects.Name.Visible = false
            continue
        end
        
        -- Calculate Box
        local boxHeight = math.abs(headPos.Y - legPos.Y)
        local boxWidth = boxHeight / 2
        local topLeft = Vector2.new(headPos.X - boxWidth/2, headPos.Y)
        local topRight = Vector2.new(headPos.X + boxWidth/2, headPos.Y)
        local bottomLeft = Vector2.new(headPos.X - boxWidth/2, legPos.Y)
        local bottomRight = Vector2.new(headPos.X + boxWidth/2, legPos.Y)
        
        -- Update Box
        if ESP.Box then
            objects.Box.PointA = topRight
            objects.Box.PointB = topLeft
            objects.Box.PointC = bottomLeft
            objects.Box.PointD = bottomRight
            objects.Box.Visible = true
        else
            objects.Box.Visible = false
        end
        
        -- Update Tracer
        if ESP.Tracers then
            local origin = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
            objects.Tracer.From = origin
            objects.Tracer.To = Vector2.new(rootPos.X, rootPos.Y)
            objects.Tracer.Visible = true
        else
            objects.Tracer.Visible = false
        end
        
        -- Update Name
        if ESP.Names then
            objects.Name.Text = player.DisplayName .. " [" .. math.floor(distance) .. "m]"
            objects.Name.Position = Vector2.new(headPos.X, headPos.Y - 25)
            objects.Name.Visible = true
        else
            objects.Name.Visible = false
        end
    end
end

-- AIMBOT FUNCTION
function GetClosestPlayer()
    local closest = nil
    local shortestDistance = Aimbot.FOV
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Head") then
            -- Team Check
            if Aimbot.TeamCheck and player.Team == LocalPlayer.Team then
                continue
            end
            
            local head = player.Character.Head
            local pos, onScreen = Camera:WorldToViewportPoint(head.Position)
            
            if onScreen then
                local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Mouse.X, Mouse.Y)).Magnitude
                if dist < shortestDistance then
                    shortestDistance = dist
                    closest = player
                end
            end
        end
    end
    
    return closest
end

