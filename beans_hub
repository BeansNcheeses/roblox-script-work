-- Create ESP for player
local function CreateESP(player)
    if player == LocalPlayer then return end
    if ESPObjects[player] then return end
    
    local objects = {
        Box = Drawing.new("Square"),
        Tracer = Drawing.new("Line"),
        Name = Drawing.new("Text"),
        Distance = Drawing.new("Text"),
        HealthBar = Drawing.new("Square"),
        HealthBarBG = Drawing.new("Square")
    }
    
    -- Box setup
    objects.Box.Thickness = 1
    objects.Box.Color = Color3.fromRGB(255, 0, 0)
    objects.Box.Filled = false
    objects.Box.Visible = false
    
    -- Tracer setup
    objects.Tracer.Thickness = 1.5
    objects.Tracer.Color = Color3.fromRGB(255, 0, 0)
    objects.Tracer.Visible = false
    
    -- Name setup
    objects.Name.Size = 13
    objects.Name.Center = true
    objects.Name.Outline = true
    objects.Name.Color = Color3.fromRGB(255, 255, 255)
    objects.Name.Visible = false
    
    -- Distance setup
    objects.Distance.Size = 11
    objects.Distance.Center = true
    objects.Distance.Outline = true
    objects.Distance.Color = Color3.fromRGB(200, 200, 200)
    objects.Distance.Visible = false
    
    -- Health bar setup
    objects.HealthBarBG.Thickness = 1
    objects.HealthBarBG.Filled = true
    objects.HealthBarBG.Color = Color3.fromRGB(0, 0, 0)
    objects.HealthBarBG.Visible = false
    
    objects.HealthBar.Thickness = 1
    objects.HealthBar.Filled = true
    objects.HealthBar.Color = Color3.fromRGB(0, 255, 0)
    objects.HealthBar.Visible = false
    
    ESPObjects[player] = objects
end

-- Remove ESP
local function RemoveESP(player)
    local objects = ESPObjects[player]
    if not objects then return end
    
    for _, obj in pairs(objects) do
        if obj.Remove then obj:Remove() end
    end
    
    ESPObjects[player] = nil
end

-- Update ESP
local function UpdateESP()
    -- Hide all if disabled
    if not Config.ESP.Enabled then
        for _, objects in pairs(ESPObjects) do
            for _, obj in pairs(objects) do
                obj.Visible = false
            end
        end
        return
    end
    
    for player, objects in pairs(ESPObjects) do
        -- Validate player
        if not player or not player.Parent then
            RemoveESP(player)
            continue
        end
        
        local character = player.Character
        if not character then
            for _, obj in pairs(objects) do obj.Visible = false end
            continue
        end
        
        local head = character:FindFirstChild("Head")
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        local root = character:FindFirstChild("HumanoidRootPart")
        
        if not head or not humanoid or not root then
            for _, obj in pairs(objects) do obj.Visible = false end
            continue
        end
        
        -- Team check
        if Config.ESP.TeamCheck and player.Team == LocalPlayer.Team then
            for _, obj in pairs(objects) do obj.Visible = false end
            continue
        end
        
        -- Distance check
        local distance = (root.Position - Camera.CFrame.Position).Magnitude
        if distance > Config.ESP.MaxDistance then
            for _, obj in pairs(objects) do obj.Visible = false end
            continue
        end
        
        -- Get positions
        local headPos, onScreen = Camera:WorldToViewportPoint(head.Position)
        if not onScreen then
            for _, obj in pairs(objects) do obj.Visible = false end
            continue
        end
        
        local legPos = Camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3, 0))
        local rootPos = Camera:WorldToViewportPoint(root.Position)
        
        -- Calculate box
        local height = math.abs(headPos.Y - legPos.Y)
        local width = height * 0.6
        
        -- Update Box
        if Config.ESP.Boxes then
            objects.Box.Size = Vector2.new(width, height)
            objects.Box.Position = Vector2.new(headPos.X - width/2, headPos.Y)
            objects.Box.Visible = true
        else
            objects.Box.Visible = false
        end
        
        -- Update Tracer
        if Config.ESP.Tracers then
            local origin = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
            if IsMobile then
                origin = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y - 100)
            end
            objects.Tracer.From = origin
            objects.Tracer.To = Vector2.new(rootPos.X, rootPos.Y)
            objects.Tracer.Visible = true
        else
            objects.Tracer.Visible = false
        end
        
        -- Update Name
        if Config.ESP.Names then
            objects.Name.Text = player.DisplayName
            objects.Name.Position = Vector2.new(headPos.X, headPos.Y - 20)
            objects.Name.Visible = true
        else
            objects.Name.Visible = false
        end
        
        -- Update Distance
        if Config.ESP.Distance then
            objects.Distance.Text = math.floor(distance) .. "m"
            objects.Distance.Position = Vector2.new(rootPos.X, legPos.Y + 5)
            objects.Distance.Visible = true
        else
            objects.Distance.Visible = false
        end
        
        -- Update Health Bar
        if Config.ESP.Health then
            local healthPercent = humanoid.Health / humanoid.MaxHealth
            local barHeight = height * healthPercent
            
            objects.HealthBarBG.Size = Vector2.new(4, height)
            objects.HealthBarBG.Position = Vector2.new(headPos.X - width/2 - 8, headPos.Y)
            objects.HealthBarBG.Visible = true
            
            objects.HealthBar.Size = Vector2.new(4, barHeight)
            objects.HealthBar.Position = Vector2.new(headPos.X - width/2 - 8, headPos.Y + height - barHeight)
            objects.HealthBar.Color = Color3.fromRGB(255 * (1 - healthPercent), 255 * healthPercent, 0)
            objects.HealthBar.Visible = true
        else
            objects.HealthBar.Visible = false
            objects.HealthBarBG.Visible = false
        end
    end
end

-- Aimbot Function
local function GetTarget()
    local center = GetScreenCenter()
    local closest = nil
    local shortestDist = Config.Aimbot.FOV
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            if Config.Aimbot.TeamCheck and player.Team == LocalPlayer.Team then
                continue
            end
            
            local targetPart = player.Character:FindFirstChild(Config.Aimbot.TargetPart)
            if not targetPart then continue end
            
            local pos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
            if not onScreen then continue end
            
            local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
            if dist < shortestDist then
                closest = player
                shortestDist = dist
            end
        end
    end
    
    return closest
end

-- Create Mobile Aim Button
local function CreateAimButton()
    if AimButton then AimButton:Destroy() end
    
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "DeltaMobileAim"
    screenGui.Parent = CoreGui
    
    AimButton = Instance.new("TextButton")
    AimButton.Name = "AimButton"
    AimButton.Size = UDim2.new(0, Config.Mobile.ButtonSize, 0, Config.Mobile.ButtonSize)
    AimButton.Position = Config.Mobile.ButtonPosition
    AimButton.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
    AimButton.BackgroundTransparency = 0.3
    AimButton.Text = "AIM"
    AimButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    AimButton.TextSize = 14
    AimButton.Font = Enum.Font.GothamBold
    AimButton.BorderSizePixel = 0
    AimButton.Parent = screenGui
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(1, 0)
    corner.Parent = AimButton
    
    local holding = false
    
    AimButton.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            holding = true
        end
    end)
    
    AimButton.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            holding = false
        end
    end)
    
    return holding
end

