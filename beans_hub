-- ESP Functions
local function CreateESP(player)
    if player == LocalPlayer then return end
    
    local espData = {
        Player = player,
        Box = nil,
        BoxFill = nil,
        Tracer = nil,
        Name = nil,
        Distance = nil,
        HealthBar = nil,
        HealthBarBG = nil,
        Weapon = nil,
        Skeleton = {},
        Highlight = nil,
        Chams = nil,
        Connections = {}
    }
    
    -- Box ESP
    espData.Box = Drawing.new("Quad")
    espData.Box.Thickness = 1
    espData.Box.Color = Config.ESP.BoxColor
    espData.Box.Filled = false
    espData.Box.Visible = false
    
    -- Box Fill
    espData.BoxFill = Drawing.new("Quad")
    espData.BoxFill.Thickness = 0
    espData.BoxFill.Color = Config.ESP.BoxFillColor
    espData.BoxFill.Filled = true
    espData.BoxFill.Transparency = Config.ESP.BoxFillTransparency
    espData.BoxFill.Visible = false
    
    -- Tracer
    espData.Tracer = Drawing.new("Line")
    espData.Tracer.Thickness = 1
    espData.Tracer.Color = Config.ESP.TracerColor
    espData.Tracer.Visible = false
    
    -- Name
    espData.Name = Drawing.new("Text")
    espData.Name.Size = 14
    espData.Name.Center = true
    espData.Name.Outline = true
    espData.Name.Color = Config.ESP.NameColor
    espData.Name.Visible = false
    
    -- Distance
    espData.Distance = Drawing.new("Text")
    espData.Distance.Size = 12
    espData.Distance.Center = true
    espData.Distance.Outline = true
    espData.Distance.Color = Color3.fromRGB(255, 255, 255)
    espData.Distance.Visible = false
    
    -- Health Bar
    espData.HealthBarBG = Drawing.new("Square")
    espData.HealthBarBG.Thickness = 1
    espData.HealthBarBG.Filled = true
    espData.HealthBarBG.Color = Color3.fromRGB(0, 0, 0)
    espData.HealthBarBG.Visible = false
    
    espData.HealthBar = Drawing.new("Square")
    espData.HealthBar.Thickness = 1
    espData.HealthBar.Filled = true
    espData.HealthBar.Color = Color3.fromRGB(0, 255, 0)
    espData.HealthBar.Visible = false
    
    -- Weapon
    espData.Weapon = Drawing.new("Text")
    espData.Weapon.Size = 12
    espData.Weapon.Center = true
    espData.Weapon.Outline = true
    espData.Weapon.Color = Color3.fromRGB(255, 255, 0)
    espData.Weapon.Visible = false
    
    -- Skeleton
    for i = 1, 12 do
        local line = Drawing.new("Line")
        line.Thickness = 1
        line.Color = Config.ESP.SkeletonColor
        line.Visible = false
        table.insert(espData.Skeleton, line)
    end
    
    -- Highlight (if character exists)
    local function SetupHighlight()
        if player.Character then
            local highlight = Instance.new("Highlight")
            highlight.FillColor = Config.ESP.HighlightColor
            highlight.OutlineColor = Config.ESP.HighlightColor
            highlight.FillTransparency = Config.ESP.HighlightFillTransparency
            highlight.OutlineTransparency = 0
            highlight.Parent = player.Character
            espData.Highlight = highlight
        end
    end
    
    -- Chams
    local function SetupChams()
        if player.Character then
            for _, part in pairs(player.Character:GetDescendants()) do
                if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                    local cham = Instance.new("BoxHandleAdornment")
                    cham.Size = part.Size
                    cham.AlwaysOnTop = true
                    cham.ZIndex = 5
                    cham.Adornee = part
                    cham.Color3 = Config.ESP.ChamsColor
                    cham.Transparency = 0.5
                    cham.Parent = part
                    if not espData.Chams then espData.Chams = {} end
                    table.insert(espData.Chams, cham)
                end
            end
        end
    end
    
    ESPObjects[player] = espData
end

local function RemoveESP(player)
    local espData = ESPObjects[player]
    if not espData then return end
    
    -- Remove Drawing objects
    if espData.Box then espData.Box:Remove() end
    if espData.BoxFill then espData.BoxFill:Remove() end
    if espData.Tracer then espData.Tracer:Remove() end
    if espData.Name then espData.Name:Remove() end
    if espData.Distance then espData.Distance:Remove() end
    if espData.HealthBar then espData.HealthBar:Remove() end
    if espData.HealthBarBG then espData.HealthBarBG:Remove() end
    if espData.Weapon then espData.Weapon:Remove() end
    
    for _, line in pairs(espData.Skeleton) do
        line:Remove()
    end
    
    -- Remove Highlight
    if espData.Highlight then
        espData.Highlight:Destroy()
    end
    
    -- Remove Chams
    if espData.Chams then
        for _, cham in pairs(espData.Chams) do
            cham:Destroy()
        end
    end
    
    -- Disconnect connections
    for _, conn in pairs(espData.Connections) do
        conn:Disconnect()
    end
    
    ESPObjects[player] = nil
end

local function UpdateESP()
    for player, espData in pairs(ESPObjects) do
        if not player or not player.Parent then
            RemoveESP(player)
            continue
        end
        
        local character = player.Character
        local humanoid = character and character:FindFirstChildOfClass("Humanoid")
        local rootPart = character and character:FindFirstChild("HumanoidRootPart")
        local head = character and character:FindFirstChild("Head")
        
        if not character or not humanoid or not rootPart or not head then
            -- Hide all ESP elements
            espData.Box.Visible = false
            espData.BoxFill.Visible = false
            espData.Tracer.Visible = false
            espData.Name.Visible = false
            espData.Distance.Visible = false
            espData.HealthBar.Visible = false
            espData.HealthBarBG.Visible = false
            espData.Weapon.Visible = false
            for _, line in pairs(espData.Skeleton) do
                line.Visible = false
            end
            continue
        end
        
        -- Team Check
        if Config.ESP.TeamCheck and player.Team == LocalPlayer.Team then
            espData.Box.Visible = false
            espData.BoxFill.Visible = false
            espData.Tracer.Visible = false
            espData.Name.Visible = false
            espData.Distance.Visible = false
            espData.HealthBar.Visible = false
            espData.HealthBarBG.Visible = false
            espData.Weapon.Visible = false
            for _, line in pairs(espData.Skeleton) do
                line.Visible = false
            end
            continue
        end
        
        -- Distance Check
        local distance = (rootPart.Position - Camera.CFrame.Position).Magnitude
        if distance > Config.ESP.MaxDistance then
            espData.Box.Visible = false
            espData.BoxFill.Visible = false
            espData.Tracer.Visible = false
            espData.Name.Visible = false
            espData.Distance.Visible = false
            espData.HealthBar.Visible = false
            espData.HealthBarBG.Visible = false
            espData.Weapon.Visible = false
            for _, line in pairs(espData.Skeleton) do
                line.Visible = false
            end
            continue
        end
        
        -- Visibility Check
        if Config.ESP.VisibleCheck then
            local ray = Ray.new(Camera.CFrame.Position, (head.Position - Camera.CFrame.Position).Unit * distance)
            local hit = Workspace:FindPartOnRayWithIgnoreList(ray, {LocalPlayer.Character, character})
            if hit and hit:IsDescendantOf(character) == false then
                espData.Box.Visible = false
                espData.BoxFill.Visible = false
                espData.Tracer.Visible = false
                espData.Name.Visible = false
                espData.Distance.Visible = false
                espData.HealthBar.Visible = false
                espData.HealthBarBG.Visible = false
                espData.Weapon.Visible = false
                for _, line in pairs(espData.Skeleton) do
                    line.Visible = false
                end
                continue
            end
        end
        
        -- Get screen positions
        local headPos, headOnScreen = Camera:WorldToViewportPoint(head.Position)
        local rootPos, rootOnScreen = Camera:WorldToViewportPoint(rootPart.Position)
        local legPos = Camera:WorldToViewportPoint(rootPart.Position - Vector3.new(0, 3, 0))
        
        if not headOnScreen then
            espData.Box.Visible = false
            espData.BoxFill.Visible = false
            espData.Tracer.Visible = false
            espData.Name.Visible = false
            espData.Distance.Visible = false
            espData.HealthBar.Visible = false
            espData.HealthBarBG.Visible = false
            espData.Weapon.Visible = false
            for _, line in pairs(espData.Skeleton) do
                line.Visible = false
            end
            continue
        end
        
        local boxHeight = math.abs(headPos.Y - legPos.Y)
        local boxWidth = boxHeight / 2
        local boxTop = Vector2.new(headPos.X - boxWidth / 2, headPos.Y)
        local boxBottom = Vector2.new(headPos.X + boxWidth / 2, legPos.Y)
        
        -- Box ESP
        if Config.ESP.Box then
            espData.Box.PointA = Vector2.new(boxTop.X, boxTop.Y)
            espData.Box.PointB = Vector2.new(boxBottom.X, boxTop.Y)
            espData.Box.PointC = Vector2.new(boxBottom.X, boxBottom.Y)
            espData.Box.PointD = Vector2.new(boxTop.X, boxBottom.Y)
            espData.Box.Color = Config.ESP.BoxColor
            espData.Box.Visible = true
            
            if Config.ESP.BoxFilled then
                espData.BoxFill.PointA = espData.Box.PointA
                espData.BoxFill.PointB = espData.Box.PointB
                espData.BoxFill.PointC = espData.Box.PointC
                espData.BoxFill.PointD = espData.Box.PointD
                espData.BoxFill.Color = Config.ESP.BoxFillColor
                espData.BoxFill.Transparency = Config.ESP.BoxFillTransparency
                espData.BoxFill.Visible = true
            else
                espData.BoxFill.Visible = false
            end
        else
            espData.Box.Visible = false
            espData.BoxFill.Visible = false
        end
        
        -- Tracers
        if Config.ESP.Tracers then
            local origin = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
            if Config.ESP.TracerOrigin == "Mouse" then
                origin = Vector2.new(Mouse.X, Mouse.Y)
            elseif Config.ESP.TracerOrigin == "Center" then
                origin = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
            end
            espData.Tracer.From = origin
            espData.Tracer.To = Vector2.new(rootPos.X, rootPos.Y)
            espData.Tracer.Color = Config.ESP.TracerColor
            espData.Tracer.Visible = true
        else
            espData.Tracer.Visible = false
        end
        
        -- Name ESP
        if Config.ESP.NameESP then
            local displayName = Config.Settings.StreamerMode and "Player" or player.DisplayName
            espData.Name.Text = displayName
            espData.Name.Position = Vector2.new(headPos.X, headPos.Y - 25)
            espData.Name.Color = Config.ESP.NameColor
            espData.Name.Visible = true
        else
            espData.Name.Visible = false
        end
        
        -- Distance ESP
        if Config.ESP.DistanceESP then
            espData.Distance.Text = math.floor(distance) .. "m"
            espData.Distance.Position = Vector2.new(rootPos.X, legPos.Y + 5)
            espData.Distance.Visible = true
        else
            espData.Distance.Visible = false
        end
        
        -- Health Bar
        if Config.ESP.HealthBar then
            local healthPercent = humanoid.Health / humanoid.MaxHealth
            local barHeight = boxHeight
            local barWidth = 3
            
            local barX = boxTop.X - 8
            if Config.ESP.HealthBarSide == "Right" then
                barX = boxBottom.X + 5
            end
            
            espData.HealthBarBG.Size = Vector2.new(barWidth, barHeight)
            espData.HealthBarBG.Position = Vector2.new(barX, boxTop.Y)
            espData.HealthBarBG.Visible = true
            
            espData.HealthBar.Size = Vector2.new(barWidth, barHeight * healthPercent)
            espData.HealthBar.Position = Vector2.new(barX, boxTop.Y + barHeight * (1 - healthPercent))
            espData.HealthBar.Color = Color3.fromRGB(255 * (1 - healthPercent), 255 * healthPercent, 0)
            espData.HealthBar.Visible = true
        else
            espData.HealthBar.Visible = false
            espData.HealthBarBG.Visible = false
        end
        
        -- Health ESP Text
        if Config.ESP.HealthESP then
            if not Config.ESP.NameESP then
                espData.Name.Text = math.floor(humanoid.Health) .. " HP"
                espData.Name.Position = Vector2.new(headPos.X, headPos.Y - 25)
                espData.Name.Color = Color3.fromRGB(255, 255, 255)
                espData.Name.Visible = true
            else
                espData.Name.Text = displayName .. " [" .. math.floor(humanoid.Health) .. " HP]"
            end
        end
        
        -- Weapon ESP
        if Config.ESP.WeaponESP then
            local tool = character:FindFirstChildOfClass("Tool")
            local weaponName = tool and tool.Name or "None"
            espData.Weapon.Text = weaponName
            espData.Weapon.Position = Vector2.new(rootPos.X, legPos.Y + (Config.ESP.DistanceESP and 20 or 5))
            espData.Weapon.Visible = true
        else
            espData.Weapon.Visible = false
        end
        
        -- Skeleton ESP
        if Config.ESP.SkeletonESP then
            -- Simplified skeleton - would need proper rig mapping for full skeleton
            local function drawBone(p1, p2, lineIndex)
                if p1 and p2 then
                    local pos1 = Camera:WorldToViewportPoint(p1.Position)
                    local pos2 = Camera:WorldToViewportPoint(p2.Position)
                    if pos1.Z > 0 and pos2.Z > 0 then
                        espData.Skeleton[lineIndex].From = Vector2.new(pos1.X, pos1.Y)
                        espData.Skeleton[lineIndex].To = Vector2.new(pos2.X, pos2.Y)
                        espData.Skeleton[lineIndex].Color = Config.ESP.SkeletonColor
                        espData.Skeleton[lineIndex].Visible = true
                    else
                        espData.Skeleton[lineIndex].Visible = false
                    end
                end
            end
            
            -- Draw basic skeleton
            if head and rootPart then
                drawBone(head, rootPart, 1)
            end
            -- Additional bones would be mapped here based on rig
        else
            for _, line in pairs(espData.Skeleton) do
                line.Visible = false
            end
        end
        
        -- Highlight
        if Config.ESP.Highlight then
            if not espData.Highlight or espData.Highlight.Parent == nil then
                SetupHighlight()
            end
            if espData.Highlight then
                espData.Highlight.FillColor = Config.ESP.HighlightColor
                espData.Highlight.FillTransparency = Config.ESP.HighlightFillTransparency
            end
        elseif espData.Highlight then
            espData.Highlight:Destroy()
            espData.Highlight = nil
        end
        
        -- Chams
        if Config.ESP.Chams then
            if not espData.Chams then
                SetupChams()
            end
            if espData.Chams then
                for _, cham in pairs(espData.Chams) do
                    cham.Color3 = Config.ESP.ChamsColor
                end
            end
        elseif espData.Chams then
            for _, cham in pairs(espData.Chams) do
                cham:Destroy()
            end
            espData.Chams = nil
        end
    end
end

-- Aimbot Functions
local function GetClosestPlayer()
    local closestPlayer = nil
    local shortestDistance = Config.Aimbot.FOV
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            -- Team Check
            if Config.Aimbot.TeamCheck and player.Team == LocalPlayer.Team then
                continue
            end
            
            local targetPart = player.Character:FindFirstChild(Config.Aimbot.TargetPart)
            if not targetPart then
                targetPart = player.Character:FindFirstChild("Head")
            end
            
            if not targetPart then continue end
            
            -- Visibility Check
            if Config.Aimbot.VisibleCheck then
                local ray = Ray.new(Camera.CFrame.Position, (targetPart.Position - Camera.CFrame.Position).Unit * 1000)
                local hit = Workspace:FindPartOnRayWithIgnoreList(ray, {LocalPlayer.Character, player.Character})
                if hit and hit:IsDescendantOf(player.Character) == false then
                    continue
                end
            end
            
            local pos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
            if onScreen then
                local distance = (Vector2.new(pos.X, pos.Y) - Vector2.new(Mouse.X, Mouse.Y)).Magnitude
                if distance < shortestDistance then
                    closestPlayer = player
                    shortestDistance = distance
                end
            end
        end
    end
    
    return closestPlayer
end

local function AimAt(target)
    if not target or not target.Character then return end
    
    local targetPart = target.Character:FindFirstChild(Config.Aimbot.TargetPart) or target.Character:FindFirstChild("Head")
    if not targetPart then return end
    
    local targetPos = targetPart.Position
    
    -- Prediction
    if Config.Aimbot.Prediction and targetPart.AssemblyLinearVelocity then
        targetPos = targetPos + (targetPart.AssemblyLinearVelocity * Config.Aimbot.PredictionAmount)
    end
    
    -- Drop Compensation (simplified)
    if Config.Aimbot.DropCompensation then
        local distance = (targetPos - Camera.CFrame.Position).Magnitude
        targetPos = targetPos + Vector3.new(0, distance * Config.Aimbot.DropAmount * 0.001, 0)
    end
    
    local cameraCF = CFrame.new(Camera.CFrame.Position, targetPos)
    
    if Config.Aimbot.Mode == "Instant" then
        Camera.CFrame = cameraCF
    elseif Config.Aimbot.Mode == "Camera" then
        Camera.CFrame = Camera.CFrame:Lerp(cameraCF, Config.Aimbot.Smoothness)
    elseif Config.Aimbot.Mode == "Mouse" then
        local pos = Camera:WorldToViewportPoint(targetPos)
        mousemoverel((pos.X - Mouse.X) * Config.Aimbot.Smoothness, (pos.Y - Mouse.Y) * Config.Aimbot.Smoothness)
    end
end

