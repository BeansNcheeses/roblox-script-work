-- SHERIFF CATEGORY
SheriffTab:CreateSection("Justice Tools")
SheriffTab:CreateButton({
   Name = "TP to Dropped Gun",
   Callback = function()
       local gun = workspace:FindFirstChild("GunDrop") or workspace:FindFirstChild("Handle", true)
       if gun and (gun.Name == "GunDrop" or gun.Parent.Name == "GunDrop") then
           game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = gun.CFrame * CFrame.new(0, 3, 0)
       else
           Rayfield:Notify({Title = "Error", Content = "Gun not found on floor!", Duration = 3})
       end
   end,
})

