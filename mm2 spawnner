-- [ FUNCTIONS ] --
local function FlingPlayer(target)
    local lp = game.Players.LocalPlayer
    local char = lp.Character
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local oldPos = hrp.CFrame
    local oldNoclip = Settings.Noclip
    
    if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        Settings.Noclip = false -- Collisions must be ON to fling
        hrp.CFrame = target.Character.HumanoidRootPart.CFrame
        
        local bV = Instance.new("BodyAngularVelocity", hrp)
        bV.AngularVelocity = Vector3.new(0, 999999, 0)
        bV.MaxTorque = Vector3.new(0, math.huge, 0)
        
        task.wait(0.3) -- Quick burst
        bV:Destroy()
        hrp.CFrame = oldPos
        Settings.Noclip = oldNoclip
    end
end

local function GlideTo(targetPos)
    local hrp = game.Players.LocalPlayer.Character.HumanoidRootPart
    local distance = (hrp.Position - targetPos).Magnitude
    local duration = distance / Settings.CoinSpeed
    local tween = game:GetService("TweenService"):Create(hrp, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = CFrame.new(targetPos)})
    tween:Play()
    return tween
end

