local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "MM2 Chaos Hub - Final",
   LoadingTitle = "Initializing Hub...",
   LoadingSubtitle = "by Gemini",
   ConfigurationSaving = {Enabled = false},
   KeySystem = false
})

local Settings = {
    RoleESP = false,
    KillAura = false,
    TargetMesh = "",
    TargetTexture = ""
}

-- MAIN TAB
local MainTab = Window:CreateTab("Combat & Visuals", 4483362458)

MainTab:CreateToggle({
   Name = "Role ESP (Murderer/Sheriff)",
   CurrentValue = false,
   Callback = function(Value) Settings.RoleESP = Value end,
})

MainTab:CreateToggle({
   Name = "Kill Aura (Must be Murderer)",
   CurrentValue = false,
   Callback = function(Value) Settings.KillAura = Value end,
})

-- SKINS TAB
local SkinTab = Window:CreateTab("Skins", 4483362458)
SkinTab:CreateSection("Knife Mesh Swapper (Visual Only)")

SkinTab:CreateInput({
   Name = "Mesh ID",
   PlaceholderText = "rbxassetid://...",
   RemoveTextAfterFocusLost = false,
   Callback = function(Text) Settings.TargetMesh = Text end,
})

SkinTab:CreateInput({
   Name = "Texture ID",
   PlaceholderText = "rbxassetid://...",
   RemoveTextAfterFocusLost = false,
   Callback = function(Text) Settings.TargetTexture = Text end,
})

SkinTab:CreateButton({
   Name = "Apply Visual Skin",
   Callback = function()
       local char = game.Players.LocalPlayer.Character
       local knife = char and char:FindFirstChild("Knife")
       if knife and knife:FindFirstChild("Handle") then
           local mesh = knife.Handle:FindFirstChildOfClass("SpecialMesh")
           if mesh then
               if Settings.TargetMesh ~= "" then mesh.MeshId = Settings.TargetMesh end
               if Settings.TargetTexture ~= "" then mesh.TextureId = Settings.TargetTexture end
               Rayfield:Notify({Title = "Success", Content = "Skin applied to hand!", Duration = 3})
           end
       else
           Rayfield:Notify({Title = "Error", Content = "Equip your default knife first!", Duration = 3})
       end
   end,
})

-- MOVEMENT TAB
local MoveTab = Window:CreateTab("Movement", 4483362458)

MoveTab:CreateSlider({
   Name = "WalkSpeed",
   Range = {16, 100},
   Increment = 1,
   CurrentValue = 16,
   Callback = function(Value)
      if game.Players.LocalPlayer.Character then
          game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = Value
      end
   end,
})

-- CORE LOGIC
game:GetService("RunService").RenderStepped:Connect(function()
    -- ESP Logic
    if Settings.RoleESP then
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= game.Players.LocalPlayer and v.Character then
                local h = v.Character:FindFirstChild("Highlight") or Instance.new("Highlight", v.Character)
                if v.Backpack:FindFirstChild("Knife") or v.Character:FindFirstChild("Knife") then
                    h.FillColor = Color3.fromRGB(255, 0, 0)
                elseif v.Backpack:FindFirstChild("Gun") or v.Character:FindFirstChild("Gun") then
                    h.FillColor = Color3.fromRGB(0, 0, 255)
                else
                    h.FillColor = Color3.fromRGB(255, 255, 255)
                end
            end
        end
    end

    -- Kill Aura Logic
    if Settings.KillAura then
        local lp = game.Players.LocalPlayer
        local char = lp.Character
        if char and char:FindFirstChild("Knife") then
            for _, v in pairs(game.Players:GetPlayers()) do
                if v ~= lp and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local dist = (char.HumanoidRootPart.Position - v.Character.HumanoidRootPart.Position).Magnitude
                    if dist < 15 then
                        local knife = char:FindFirstChild("Knife")
                        if knife:FindFirstChild("Stab") then
                            knife.Stab:FireServer()
                        end
                    end
                end
            end
        end
    end
end)
