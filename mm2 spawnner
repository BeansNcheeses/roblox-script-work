-- [ CORE LOGIC ] --
game:GetService("RunService").Stepped:Connect(function()
    local lp = game.Players.LocalPlayer
    local char = lp.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end

    -- Noclip & God Mode
    if (Settings.Noclip or Settings.AutoCoin or Settings.GodMode) and char then
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end
    
    if Settings.GodMode then
        char.HumanoidRootPart.CFrame = char.HumanoidRootPart.CFrame * CFrame.new(0, 0, 0) -- Keeps physics active but prevents collisions
    end

    -- Role ESP
    if Settings.RoleESP then
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= lp and v.Character then
                local h = v.Character:FindFirstChild("Highlight") or Instance.new("Highlight", v.Character)
                if v.Backpack:FindFirstChild("Knife") or v.Character:FindFirstChild("Knife") then
                    h.FillColor = Color3.fromRGB(255, 0, 0)
                elseif v.Backpack:FindFirstChild("Gun") or v.Character:FindFirstChild("Gun") then
                    h.FillColor = Color3.fromRGB(0, 0, 255)
                else
                    h.FillColor = Color3.fromRGB(255, 255, 255)
                end
            end
        end
    end
end)

-- Auto-Coin Glide Loop
spawn(function()
    while true do
        task.wait(0.5)
        if Settings.AutoCoin then
            local coins = workspace:FindFirstChild("CoinContainer", true)
            if coins then
                for _, coin in pairs(coins:GetChildren()) do
                    if coin:IsA("BasePart") and Settings.AutoCoin then
                        local t = GlideTo(coin.Position)
                        t.Completed:Wait()
                        task.wait(0.1)
                    end
                end
            end
        end
    end
end)
