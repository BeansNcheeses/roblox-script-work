local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "MM2 Mega Hub | Glow ESP",
   LoadingTitle = "Loading Chaos...",
   LoadingSubtitle = "by Gemini",
   ConfigurationSaving = {Enabled = false}
})

-- [ TABS ] --
local VisualsTab = Window:CreateTab("Visuals", 4483362458)
local MainTab = Window:CreateTab("Main", 4483362458)

-- [ VISUALS SECTION ] --
VisualsTab:CreateSection("Glow ESP (Body Highlight)")

VisualsTab:CreateToggle({
   Name = "Enable Body Glow",
   CurrentValue = false,
   Callback = function(Value)
       _G.GlowESP = Value
       if not Value then
           -- Clean up highlights when turned off
           for _, v in pairs(game.Players:GetPlayers()) do
               if v.Character and v.Character:FindFirstChild("GlowHighlight") then
                   v.Character.GlowHighlight:Destroy()
               end
           end
       end
   end,
})

-- [ MAIN SECTION ] --
MainTab:CreateSection("Quick Utilities")
MainTab:CreateButton({
   Name = "TP to Gun",
   Callback = function()
       local gun = workspace:FindFirstChild("GunDrop") or workspace:FindFirstChild("Handle", true)
       if gun and (gun.Name == "GunDrop" or gun.Parent.Name == "GunDrop") then
           game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = gun.CFrame
       end
   end,
})

-- [ ESP ENGINE ] --
-- This runs in the background to keep the glow updated
task.spawn(function()
    while true do
        task.wait(1) -- Check roles every second
        if _G.GlowESP then
            for _, v in pairs(game.Players:GetPlayers()) do
                if v ~= game.Players.LocalPlayer and v.Character then
                    local char = v.Character
                    local highlight = char:FindFirstChild("GlowHighlight")
                    
                    if not highlight then
                        highlight = Instance.new("Highlight", char)
                        highlight.Name = "GlowHighlight"
                        highlight.FillTransparency = 0.5
                        highlight.OutlineTransparency = 0
                    end
                    
                    -- Update Color based on Role
                    if v.Backpack:FindFirstChild("Knife") or char:FindFirstChild("Knife") then
                        highlight.FillColor = Color3.fromRGB(255, 0, 0) -- Red for Murderer
                        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                    elseif v.Backpack:FindFirstChild("Gun") or char:FindFirstChild("Gun") then
                        highlight.FillColor = Color3.fromRGB(0, 0, 255) -- Blue for Sheriff
                        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                    else
                        highlight.FillColor = Color3.fromRGB(200, 200, 200) -- Grey for Innocent
                        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                    end
                end
            end
        end
    end
end)

-- [ FORCE UI TO LOAD ] --
Rayfield:Notify({
    Title = "Hub Loaded",
    Content = "Menu is now active!",
    Duration = 5
})
