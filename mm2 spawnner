local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "MM2 Mobile Chaos - v8",
   LoadingTitle = "Mobile Optimization Active",
   LoadingSubtitle = "by Gemini",
   ConfigurationSaving = {Enabled = false},
   KeySystem = false
})

local Settings = {
    KillAura = false,
    AuraRange = 25,
    KillAll = false,
    Noclip = false
}

-- COMBAT TAB
local CombatTab = Window:CreateTab("Combat", 4483362458)

CombatTab:CreateToggle({
   Name = "Kill Aura",
   CurrentValue = false,
   Callback = function(Value) Settings.KillAura = Value end,
})

CombatTab:CreateToggle({
   Name = "KILL ALL (TP Loop)",
   CurrentValue = false,
   Callback = function(Value) 
       Settings.KillAll = Value 
       if Value then
           Settings.KillAura = true -- Auto-enable aura for Kill All
       end
   end,
})

-- UTILITY TAB
local UtilTab = Window:CreateTab("Utilities", 4483362458)

UtilTab:CreateButton({
   Name = "TP to Dropped Gun",
   Callback = function()
       local gun = workspace:FindFirstChild("GunDrop") or workspace:FindFirstChild("Handle", true)
       if gun and (gun.Name == "GunDrop" or gun.Parent.Name == "GunDrop") then
           game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = gun.CFrame * CFrame.new(0, 3, 0)
       else
           Rayfield:Notify({Title = "Error", Content = "Gun not found!", Duration = 2})
       end
   end,
})

UtilTab:CreateToggle({
   Name = "Ghost Mode (Noclip)",
   CurrentValue = false,
   Callback = function(Value) Settings.Noclip = Value end,
})

-- MOVEMENT TAB
local MoveTab = Window:CreateTab("Movement", 4483362458)

local Flying = false
local FlyBtn = MoveTab:CreateButton({
   Name = "Toggle Fly (Mobile)",
   Callback = function()
       Flying = not Flying
       local lp = game.Players.LocalPlayer
       local char = lp.Character
       local hp = char:WaitForChild("HumanoidRootPart")
       
       if Flying then
           local bv = Instance.new("BodyVelocity", hp)
           bv.Name = "MobileFlight"
           bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
           spawn(function()
               while Flying do
                   bv.Velocity = workspace.CurrentCamera.CFrame.LookVector * 50
                   task.wait()
               end
               bv:Destroy()
           end)
       end
   end,
})

-- CORE ENGINE
game:GetService("RunService").Stepped:Connect(function()
    local lp = game.Players.LocalPlayer
    local char = lp.Character
    
    -- NOCLIP LOGIC
    if Settings.Noclip and char then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end

    -- KILL ALL / AURA LOGIC
    if Settings.KillAura and char and char:FindFirstChild("Knife") then
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= lp and v.Character and v.Character:FindFirstChild("Humanoid") and v.Character.Humanoid.Health > 0 then
                local targetHRP = v.Character:FindFirstChild("HumanoidRootPart")
                if targetHRP then
                    local dist = (char.HumanoidRootPart.Position - targetHRP.Position).Magnitude
                    
                    -- If Kill All is ON, TP to them
                    if Settings.KillAll then
                        char.HumanoidRootPart.CFrame = targetHRP.CFrame * CFrame.new(0, 3, 0)
                    end
                    
                    -- Attack if in range
                    if dist <= Settings.AuraRange or Settings.KillAll then
                        local knife = char:FindFirstChild("Knife")
                        if knife:FindFirstChild("Stab") then
                            knife.Stab:FireServer()
                        end
                    end
                    
                    if Settings.KillAll then break end -- Focus one player at a time for stability
                end
            end
        end
    end
end)
